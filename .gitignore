# .gitignore for Python / Jupyter data analysis projects

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Jupyter Notebook
.ipynb_checkpoints/
# Ignore notebook conversion artifacts (optional)
*.nbconvert.ipynb

# IPython
profile_default/
ipython_config.py

# Virtual environments
.env
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# IDEs and editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Database, serialized and large binary outputs
*.sqlite
*.db
*.h5
*.hdf5
*.pkl
*.joblib

# Logs
*.log

# Results / outputs
/results/
/outputs/

# Secrets and environment files
.env.local
.env.*.local

# Large data files (comment out if you want to include data in repo)
# /data/
# *.csv
Crime_Data_from_2020_to_Present.csv
# *.tsv
# *.xlsx
# *.xls
# *.parquet
# *.feather
# *.sav

# Notes:
# - Notebooks (.ipynb) are NOT ignored by default so they can be tracked.
# - Uncomment the data lines above if you want to exclude datasets from the repo.
# - Adjust this file to match any custom folders you use for outputs or environments.

